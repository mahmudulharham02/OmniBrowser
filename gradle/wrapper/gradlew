##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell available, it is
#       recommended to use that to run this script.
#
#   (2) The Java VM arguments should not contain spaces and should be enclosed
#       in quotes if necessary:
#
#           GRADLE_OPTS="-Xmx64m -Xms64m" (in Linux/Mac)
#           set GRADLE_OPTS=-Xmx64m -Xms64m (in Windows)
#
#   NOTE: This script does not take any command arguments, it just sets the
#         default Java settings to be compatible with Gradle.
#
#           Note: on CYGWIN and on all other Unix boxes, the normal shell Main
#           Start Main will thus use the parameters in this script.
#
# You can find Gradle at https://gradle.org
#
##############################################################################

# Attempt to set APP_HOME
# Resolve links: $0 may be a link
app_path="$0"

# Need this for daisy-chained symlinks.
while
    APP_HOME=$( cd "$(dirname "$app_path")" && pwd -P )
    app_path=$(readlink "$app_path")
do
    APP_HOME=$( cd "$(dirname "$app_path")" && pwd -P )
done

APP_HOME=$( cd "${APP_HOME%"${APP_HOME##*/}"}" && pwd -P ) || exit

APP_NAME="Gradle"
APP_BASE_NAME=${0##*/}
export CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

# Add default JVM options here. You can also use JAVA_OPTS and GRADLE_OPTS to pass JVM options to this script.
DEFAULT_JVM_OPTS='"-Dorg.gradle.appname=$APP_BASE_NAME" "-Xmx64m" "-Xms64m"'

# Use the maximum available, or set MAX_FD != "max" to use that value.
MAX_FD=maximum

warn ()
{
    echo "$*" >&2
}

die ()
{
    echo
    echo "$*"
    echo
    exit 1
}

# OS specific support (must be 'true' or 'false').
darwin=false
msys=false
case "$( uname )" in                #(
  DARWIN* )         darwin=true  ;; #(
  MINGW* )          msys=true   ;; #(
  NONGNU* )         msys=true   ;; #(
esac

# Determine the Java command to use in order to perform the syntax check.
not_called_arg0=$( basename -- "$0" )
if [[ -z "$JAVA_HOME" ]] && command -v java &> /dev/null; then
    JAVA_HOME=$( java -XshowSettings:properties -version 2>&1 | grep 'java.home' | awk '{print $NF}' | tr -d \\r )
fi
[[ -n "$JAVA_HOME" ]] || die "JAVA_HOME is not set and cannot be found."

if ! "$JAVA_HOME/bin/java" -version 2>&1 | grep -q "version"; then
    die "ERROR: JAVA_HOME is not pointing to a working JDK."
fi

if [[ -z "$JAVA_HOME" ]]; then
    JAVA="java"
else
    JAVA="$JAVA_HOME/bin/java"
fi

if [[ -z "$CLASSPATH" ]]; then
    CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
fi

# Now convert the arguments - kludge to limit ourselves to /bin/sh
for arg do
    if
        case $arg in                                #(
          -*)   false ;;                            # don't mess with options #(
          /?*)  t=${arg#/} t=/${t%%/*}              # looks like a POSIX filepath
                [ -e "$t" ] ;;                      #(
          *)    false ;; 
        esac
    then
        arg=$( cygpath --path --mixed "$arg" )
    fi
    arg=$( printf '%s\n' "$arg" | sed "s/'/'\\\\''/g" ) # if arg looks like a file path, treat it as such
    APP_ARGS=$( printf '%s\n' "$APP_ARGS $arg" )
done

# Collect all arguments for the java command; in some configs .in files
# might end up in the classpath accidentally.
for arg in "$@" ; do
    arg=$( printf '%s\n' "$arg" | sed "s/'/'\\\\''/g" ) # if arg looks like a file path, treat it as such
    APP_ARGS=$( printf '%s\n' "$APP_ARGS $arg" )
done

# Use "xargs" to parse quoted args.
#
# With -n1 it outputs one arg per line, with $'\n' as the delimiter, and
# then we prepend the all arg on a single line as before.
set -- $(
        printf '%s\n' "$APP_ARGS" |
        sed 's/[^\\]\\.[^ ]*//g' | # remove .;\\ and all that follows
        tr '\n' ' ' # convert newlines to spaces
    ) "$@"

# Collect all arguments for the java command, following the shell quoting and substitution rules
eval "set -- $(printf '%s ' "$APP_ARGS")"

exec "$JAVA" $DEFAULT_JVM_OPTS -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
